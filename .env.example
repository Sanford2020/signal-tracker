# Application
APP_ENV=development
APP_NAME=Signal Tracker API
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=INFO
ADMIN_API_KEY=
ADMIN_RATE_LIMIT_PER_MINUTE=30

# Database
DATABASE_URL=postgresql+psycopg://signal_tracker:signal_tracker@localhost:5432/signal_tracker
POSTGRES_USER=signal_tracker
POSTGRES_PASSWORD=signal_tracker
POSTGRES_DB=signal_tracker
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
REDIS_PORT=6379
SOURCE_CHECK_INTERVAL_SECONDS=900
LIFECYCLE_WORKER_INTERVAL_SECONDS=3600
NOTIFICATION_DELIVERY_INTERVAL_SECONDS=300

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# AI extraction (mock by default — no API key required)
AI_EXTRACTION_MODE=mock
AI_API_KEY=
AI_MODEL=mock
AI_BASE_URL=

# Lifecycle / alerts
LIFECYCLE_DORMANCY_DAYS=14
ALERT_OPPORTUNITY_THRESHOLD=7.0
ALERT_CREDIBILITY_INCREASE_MIN=2.0
ALERT_RISK_THRESHOLD=7.0
ALERT_HEAT_SPIKE_MIN=2.0

# Source providers
GITHUB_API_TOKEN=
GITHUB_PROVIDER_MAX_REPOSITORIES=3
GITHUB_PROVIDER_MAX_RELEASES_PER_REPO=2
GITHUB_PROVIDER_MAX_ACTIVITY_ITEMS_PER_REPO=2
GITHUB_PROVIDER_TIMEOUT_SECONDS=10.0
RSS_FEED_URLS=
RSS_PROVIDER_MAX_ENTRIES_PER_FEED=20
RSS_PROVIDER_TIMEOUT_SECONDS=10.0
HACKER_NEWS_PROVIDER_MAX_HITS=10
HACKER_NEWS_PROVIDER_TIMEOUT_SECONDS=10.0
HACKER_NEWS_PROVIDER_TAGS=story

# Usage controls
USAGE_AI_EXTRACTION_MONTHLY_LIMIT=10000
USAGE_SOURCE_CHECK_MONTHLY_LIMIT=100000
